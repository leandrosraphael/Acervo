<%
'/********************************************************/
'/*   DEFINIÇÕES DE CORES E ESTILO DO TERMINAL WEB ASP   */
'/********************************************************/
response.write "<style type='text/css'><!--"

response.write "body, table, tr, td, p, font, a, select"
response.write "{"
response.write "    font-family: " & css_geral_fonte & ";"
response.write "}"
response.write "input[type='text'],"
response.write "input[type='password']"
response.write "{"
response.write "    font-size: " & css_geral_tamanho_fonte & "px;"
response.write "    font-family: " & css_geral_fonte & " !important;"
response.write "    border: 1px solid " & css_busca_inputs & ";"
response.write "}"
response.write "input[type='button']"
response.write "{"
response.write "    font-size: " & css_geral_botao_tamanho_fonte & "px;"
response.write "    font-family: " & css_geral_fonte & " !important;"
response.write "    border: 1px solid " & css_geral_botao_cor_margem & ";"
response.write "    background-color: " & css_geral_botao_background & ";"
response.write "    color: " & css_geral_botao_cor_fonte & ";"
response.write "}"
response.write "textarea"
response.write "{"
response.write "    font-size: " & css_geral_tamanho_fonte & "px;"
response.write "    font-family: " & css_geral_fonte & " !important;"
response.write "    border: 1px solid " & css_busca_inputs & ";"
response.write "}"
response.write "select"
response.write "{"
response.write "    border: 1px solid " & css_busca_inputs & ";"
response.write "}"
